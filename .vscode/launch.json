    "version": "0.2.0",
    "configurations": [
        {
            "name": ".NET Debug",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build-debug",
            "program": "${workspaceFolder}/WILK/bin/Debug/net8.0-windows/WILK.dll",
            "args": [],
            "cwd": "${workspaceFolder}/WILK",
            "console": "internalConsole",
            "stopAtEntry": false,
            "justMyCode": false,
            "symbolOptions": {
                "searchPaths": [
                    "${workspaceFolder}/WILK/bin/Debug/net8.0-windows"
                ],
                "searchMicrosoftSymbolServer": true
            }
        },
